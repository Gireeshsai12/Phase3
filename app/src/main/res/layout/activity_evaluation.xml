<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Course Evaluation"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etCourse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Course ID ex: cs101" />

    <EditText
        android:id="@+id/etRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Rating 1-5"
        android:inputType="number" />

    <EditText
        android:id="@+id/etFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Feedback"
        android:minLines="3" />

    <Button
        android:id="@+id/btnSubmitEval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Submit Evaluation" />

    <Button
        android:id="@+id/btnViewGrade"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="View Grade After Evaluation" />

    <TextView
        android:id="@+id/tvGradeResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Grade will appear here"
        android:textSize="18sp"
        android:layout_marginTop="20dp" />

</LinearLayout>